# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit it.

# ── Authentication ──────────────────────────────────────────────────────────────
# Username for the panel login (default: admin)
ADMIN_USERNAME=admin

# Password — leave empty to DISABLE authentication (not recommended in production)
ADMIN_PASSWORD=

# Session duration in hours before the user is logged out (default: 24)
SESSION_EXPIRE_HOURS=24

# ── Services config ─────────────────────────────────────────────────────────────
# Path inside the container to your services JSON file.
# The default (./config/services.json mounted to /app/config/services.json) is fine
# for most setups and doesn't need to be changed.
# SERVICES_CONFIG_PATH=/app/config/services.json
